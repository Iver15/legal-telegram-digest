---
import dayjs from '../lib/dayjs'
import { Icon } from 'astro-icon/components'
import { formatCompactNumberRu, formatPercentRu, getReactionCount } from '../lib/metrics'

const locale = import.meta.env.LOCALE || 'ru'
const timezone = import.meta.env.TIMEZONE || 'Europe/Moscow'

locale && dayjs.locale(locale)

const SITE_URL = import.meta.env.BASE_URL ?? '/'
const { post, isItem = false, collapsible = false } = Astro.props

const channel = import.meta.env.CHANNEL || 'neuraldeep'
const postNumericId = post.id.includes('/') ? post.id.split('/').pop() : post.id
const tgChannel = post.channel || channel
const tgLink = `https://t.me/${tgChannel}/${postNumericId}`
const COMMENTS = import.meta.env.COMMENTS
const REACTIONS = import.meta.env.REACTIONS || 'true'

const datetime = dayjs(post.datetime).tz(timezone)
const timeago = datetime.isBefore(dayjs().subtract(1, 'w')) ? datetime.format('HH:mm · ll · ddd') : datetime.fromNow()
const hasContent = post.content.length > 0
const hasReactions = Boolean(REACTIONS && post.reactions?.length > 0)
const hasTags = post.tags.length > 0
const legalTopics = post.legalTopics || []
const priorityScore = post.priorityScore || 0
const summary = post.digestSummary || post.text?.slice(0, 240) || ''
const reactionCount = post.reactionCount ?? getReactionCount(post)
const viewCount = post.viewCount
const engagementRate = post.engagementRate
const hasSignals = reactionCount > 0 || Boolean(viewCount) || typeof engagementRate === 'number'
const channelAvatar = post.channelAvatar
const isNew = datetime.isAfter(dayjs().subtract(3, 'h'))
const wordCount = (post.text || '').split(/\s+/).filter(Boolean).length
const readingMinutes = Math.max(1, Math.round(wordCount / 200))

const priorityLevel = priorityScore >= 7 ? 'high' : priorityScore >= 4 ? 'medium' : ''
---

<article class="feed-item-card" style={{ 'view-transition-name': `post-${post.id}` }}>
  <!-- Header row: avatar + channel + time + badges + actions -->
  <div class="feed-item-card__header">
    {
      channelAvatar && (
        <img
          src={channelAvatar}
          alt={post.channelTitle || post.channel}
          class="feed-item-card__avatar"
          loading="lazy"
          width="28"
          height="28"
        />
      )
    }
    <div class="feed-item-card__meta">
      <span class="feed-item-card__source">@{post.channel}</span>
      <span class="feed-item-card__time">{timeago}</span>
      <span class="feed-item-card__time">· {readingMinutes} мин</span>
      {isNew && <span class="badge badge--new">new</span>}
      {
        post.category && (
          <span class="badge" data-cat={post.category}>
            {post.category}
          </span>
        )
      }
      {
        priorityScore > 0 && (
          <span
            class:list={[
              'priority-badge',
              priorityLevel === 'high' && 'priority-badge--high',
              priorityLevel === 'medium' && 'priority-badge--medium',
            ]}
          >
            {priorityScore.toFixed(1)}
          </span>
        )
      }
    </div>
    <div class="feed-item-card__actions">
      <a href={`${SITE_URL}posts/${post.id}/`} class="badge">читать</a>
      <a href={tgLink} target="_blank" rel="noopener noreferrer" class="badge">Telegram</a>
    </div>
  </div>

  <!-- Signals -->
  {
    hasSignals && (
      <div class="feed-item-card__signals">
        {typeof viewCount === 'number' && (
          <span class="signal-chip signal-chip--views">
            <Icon name="ri:eye-line" class="signal-chip__icon" />
            {formatCompactNumberRu(viewCount)}
          </span>
        )}
        {reactionCount > 0 && (
          <span class="signal-chip signal-chip--reactions">
            <Icon name="ri:heart-line" class="signal-chip__icon" />
            {formatCompactNumberRu(reactionCount)}
          </span>
        )}
        {typeof engagementRate === 'number' && (
          <span class="signal-chip signal-chip--er">
            <Icon name="ri:bar-chart-line" class="signal-chip__icon" />
            {formatPercentRu(engagementRate, 1)}
          </span>
        )}
      </div>
    )
  }

  <!-- Full content (HTML preserved from source) -->
  {
    collapsible ? (
      <>
        <div class="feed-item-card__body">{summary}</div>
        {hasContent && (
          <details class="feed-item-card__details">
            <summary class="feed-item-card__toggle">Развернуть полностью</summary>
            <div class="feed-item-card__body content" set:html={post.content} />
          </details>
        )}
      </>
    ) : hasContent ? (
      <div class="feed-item-card__body content" set:html={post.content} />
    ) : (
      <div class="feed-item-card__body">{summary}</div>
    )
  }

  <!-- Reactions -->
  {
    hasReactions && (
      <div class="feed-item-card__footer">
        {post.reactions.map((reaction) => (
          <span class="badge">
            {reaction.isPaid ? (
              '\u2B50'
            ) : reaction.emojiImage ? (
              <img
                src={reaction.emojiImage}
                alt={reaction.emoji || 'emoji'}
                loading="lazy"
                width="16"
                height="16"
                style="width:1em;height:1em;vertical-align:-0.15em;"
              />
            ) : (
              reaction.emoji
            )}
            {reaction.count}
          </span>
        ))}
      </div>
    )
  }

  <!-- Tags -->
  {
    hasTags && (
      <div class="feed-item-card__footer">
        {post.tags.map((tag) => (
          <a href={`${SITE_URL}search/%23${tag}/`} class="badge">
            {tag}
          </a>
        ))}
      </div>
    )
  }

  {
    COMMENTS && isItem && (
      <section class="feed-item-card__body" aria-label="Comments">
        <script
          is:inline
          async
          src="https://telegram.org/js/telegram-widget.js"
          data-telegram-discussion={`${channel}/${post.id}`}
          data-comments-limit="50"
          data-colorful="1"
          data-color="454545"
        />
      </section>
    )
  }
</article>
