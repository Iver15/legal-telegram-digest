---
import dayjs from '../lib/dayjs'
import { formatCompactNumberRu, formatPercentRu, getReactionCount } from '../lib/metrics'

const locale = import.meta.env.LOCALE || 'ru'
const timezone = import.meta.env.TIMEZONE || 'Europe/Moscow'

locale && dayjs.locale(locale)

const SITE_URL = import.meta.env.BASE_URL ?? '/'
const { post, isItem = false, collapsible = false } = Astro.props

const channel = import.meta.env.CHANNEL || 'neuraldeep'
const postNumericId = post.id.includes('/') ? post.id.split('/').pop() : post.id
const tgChannel = post.channel || channel
const tgLink = `https://t.me/${tgChannel}/${postNumericId}`
const COMMENTS = import.meta.env.COMMENTS
const REACTIONS = import.meta.env.REACTIONS || 'true'

const datetime = dayjs(post.datetime).tz(timezone)
const timeago = datetime.isBefore(dayjs().subtract(1, 'w')) ? datetime.format('HH:mm · ll · ddd') : datetime.fromNow()
const hasContent = post.content.length > 0
const hasReactions = Boolean(REACTIONS && post.reactions?.length > 0)
const hasTags = post.tags.length > 0
const legalTopics = post.legalTopics || []
const priorityScore = post.priorityScore || 0
const summary = post.digestSummary || post.text?.slice(0, 240) || ''
const reactionCount = post.reactionCount ?? getReactionCount(post)
const viewCount = post.viewCount
const engagementRate = post.engagementRate
const hasSignals = reactionCount > 0 || Boolean(viewCount) || typeof engagementRate === 'number'
const channelAvatar = post.channelAvatar
---

<article
  class:list={['post-card transition duration-200', collapsible && 'post-card--collapsible']}
  style={{ 'view-transition-name': `post-${post.id}` }}
>
  <header class="post-card__header">
    <div class="flex min-w-0 items-start gap-3">
      {
        channelAvatar && (
          <img
            src={channelAvatar}
            alt={post.channelTitle || post.channel || 'Канал'}
            class="mt-0.5 h-11 w-11 shrink-0 rounded-full border border-line object-cover shadow-soft"
            loading="lazy"
            width="44"
            height="44"
          />
        )
      }
      <div class="min-w-0 flex-1">
        <div class="post-card__channel-line">
          <span class="post-card__channel-title">{post.channelTitle || 'Канал'}</span>
          {post.channel && <span class="post-card__channel-handle">@{post.channel}</span>}
        </div>
        <div class="mt-1.5 flex flex-wrap items-center gap-2 text-[12px] text-dim">
          <span>{timeago}</span>
          {post.category && <span class="badge">{post.category}</span>}
        </div>
      </div>
    </div>
    <div class="post-card__actions">
      <a href={`${SITE_URL}posts/${post.id}`} title="Открыть карточку поста" class="post-card__telegram badge">читать</a
      >
      <a
        href={tgLink}
        target="_blank"
        rel="noopener noreferrer"
        title="Открыть в Telegram"
        class="post-card__telegram badge"
      >
        Telegram
      </a>
    </div>
  </header>

  {
    (post.category || legalTopics.length > 0 || priorityScore > 0) && (
      <div class="post-card__meta">
        {legalTopics.slice(0, 4).map((topic) => (
          <span class="badge">#{topic}</span>
        ))}
        {priorityScore > 0 && <span class="badge">приоритет {priorityScore.toFixed(1)}</span>}
      </div>
    )
  }

  {
    hasSignals && (
      <div class="post-card__signals">
        {typeof viewCount === 'number' && <span class="badge">👁 {formatCompactNumberRu(viewCount)}</span>}
        {reactionCount > 0 && <span class="badge">❤ {formatCompactNumberRu(reactionCount)}</span>}
        {typeof engagementRate === 'number' && <span class="badge">ER {formatPercentRu(engagementRate, 1)}</span>}
      </div>
    )
  }

  {
    collapsible ? (
      <>
        <div class="post-card__preview text-[15px] leading-[1.75] text-body">{summary}</div>
        {hasContent && (
          <details class="post-card__details">
            <summary class="post-card__summary-toggle">Развернуть полностью</summary>
            <div class="post-card__details-content content" set:html={post.content} />
          </details>
        )}
      </>
    ) : hasContent ? (
      <div
        class:list={['post-card__body content', !hasReactions && !hasTags && !COMMENTS && !hasSignals && 'pb-6']}
        set:html={post.content}
      />
    ) : (
      <div class="post-card__body pt-3 text-[15px] leading-[1.7] text-dim">{summary}</div>
    )
  }

  {
    hasReactions && (
      <div class="post-card__footer pt-0">
        {post.reactions.map((reaction) => (
          <span
            class:list={[
              'inline-flex items-center gap-1 rounded-full border border-line bg-code px-2.5 py-1 text-[12px] text-muted',
              reaction.isPaid && 'border-[rgba(255,196,0,0.35)] bg-[rgba(255,196,0,0.12)] text-[#9a6a00]',
            ]}
          >
            <span class="inline-flex items-center text-[14px] leading-none">
              {reaction.isPaid ? (
                '\u2B50'
              ) : reaction.emojiImage ? (
                <img
                  src={reaction.emojiImage}
                  alt={reaction.emoji || 'emoji'}
                  loading="lazy"
                  width="20"
                  height="20"
                  class="block h-[1em] w-[1em]"
                />
              ) : (
                reaction.emoji
              )}
            </span>
            <span class="font-medium opacity-80 [font-variant-numeric:tabular-nums]">{reaction.count}</span>
          </span>
        ))}
      </div>
    )
  }

  {
    hasTags && (
      <footer class="post-card__footer pt-0">
        {post.tags.map((tag) => (
          <a href={`${SITE_URL}search/%23${tag}`} title={tag} class="badge hover:no-underline">
            {tag}
          </a>
        ))}
      </footer>
    )
  }

  {
    COMMENTS && isItem && (
      <section class="post-card__body pt-0" aria-label="Comments">
        <script
          is:inline
          async
          src="https://telegram.org/js/telegram-widget.js"
          data-telegram-discussion={`${channel}/${post.id}`}
          data-comments-limit="50"
          data-colorful="1"
          data-color="454545"
        />
      </section>
    )
  }
</article>
