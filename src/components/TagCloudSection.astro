---
export interface Item {
  href: string
  label: string
  title?: string
  external?: boolean
}

const { title, items } = Astro.props as {
  title: string
  items: Item[]
}
---

<section class="tag-cloud-section" aria-labelledby={`${title.toLowerCase()}-title`}>
  <h1 id={`${title.toLowerCase()}-title`} class="tag-cloud-title">{title}</h1>

  <ul class="tag-cloud" role="list">
    {
      items.map((item) => (
        <li class="tag-cloud-item">
          <a
            href={item.href}
            class="tag-cloud-link"
            title={item.title ?? item.label}
            target={item.external ? '_blank' : undefined}
            rel={item.external ? 'noopener noreferrer' : undefined}
          >
            {item.label}
          </a>
        </li>
      ))
    }
  </ul>
</section>
