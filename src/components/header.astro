---
import { Icon } from 'astro-icon/components'
import voidFile from '../assets/void.png'

const SITE_URL = import.meta.env.BASE_URL ?? '/'
const RSS_URL = `${SITE_URL}rss.xml`
const { channel } = Astro.props

const TWITTER = import.meta.env.TWITTER
const GITHUB = import.meta.env.GITHUB
const TELEGRAM = import.meta.env.TELEGRAM
const DISCORD = import.meta.env.DISCORD
const MASTODON = import.meta.env.MASTODON
const BLUESKY = import.meta.env.BLUESKY
const hideDescription = import.meta.env.HIDE_DESCRIPTION

const socialLinks = [
  {
    href: RSS_URL,
    title: 'RSS-лента',
    label: 'RSS-лента',
    icon: 'ri:rss-line',
    rel: 'alternate noopener noreferrer',
    type: 'application/rss+xml',
  },
  TWITTER &&
    TWITTER.length > 0 && {
      href: `https://x.com/${TWITTER}`,
      title: 'Twitter',
      label: 'Twitter / X',
      icon: 'ri:twitter-x-line',
      rel: 'noopener noreferrer',
    },
  GITHUB &&
    GITHUB.length > 0 && {
      href: `https://github.com/${GITHUB}`,
      title: 'GitHub',
      label: 'GitHub',
      icon: 'ri:github-line',
      rel: 'noopener noreferrer',
    },
  TELEGRAM &&
    TELEGRAM.length > 0 && {
      href: `https://t.me/${TELEGRAM}`,
      title: 'Telegram',
      label: 'Telegram',
      icon: 'ri:telegram-line',
      rel: 'noopener noreferrer',
    },
  DISCORD &&
    DISCORD.length > 0 && {
      href: DISCORD,
      title: 'Discord',
      label: 'Discord',
      icon: 'ri:discord-line',
      rel: 'noopener noreferrer',
    },
  MASTODON &&
    MASTODON.length > 0 && {
      href: `https://${MASTODON}`,
      title: 'Mastodon',
      label: 'Mastodon',
      icon: 'ri:mastodon-line',
      rel: 'noopener noreferrer',
    },
  BLUESKY &&
    BLUESKY.length > 0 && {
      href: `https://bsky.app/profile/${BLUESKY}`,
      title: 'BlueSky',
      label: 'Bluesky',
      icon: 'ri:bluesky-line',
      rel: 'noopener noreferrer',
    },
].filter(Boolean)
---

<header class="channel-header">
  <a href={SITE_URL} title={channel?.title}>
    <img
      src={channel?.avatar?.startsWith('http') ? channel?.avatar : voidFile.src}
      alt={channel?.title}
      loading="eager"
      fetchpriority="high"
      width="40"
      height="40"
      class="channel-header__avatar"
    />
  </a>
  <a href={SITE_URL} class="channel-header__title" title={channel?.title}>
    {channel?.title}
  </a>
  <nav class="channel-header__nav" aria-label="Ссылки канала">
    {
      socialLinks.map((item) => (
        <a
          href={item.href}
          title={item.title}
          target="_blank"
          rel={item.rel}
          type={item.type}
          aria-label={item.label}
          class="channel-header__social"
        >
          <Icon name={item.icon} class="channel-header__social-icon" aria-hidden="true" />
        </a>
      ))
    }
  </nav>
</header>

{
  hideDescription !== 'true' && channel?.descriptionHTML && channel?.descriptionHTML.length > 0 && (
    <div class="channel-intro content" set:html={channel?.descriptionHTML} />
  )
}
