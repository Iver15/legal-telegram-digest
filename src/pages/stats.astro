---
import Layout from '../layouts/base.astro'
import { getAllCategories, getAllChannels, getAllPosts, getChannelData, getDigestTitle } from '../lib/data'
import { formatCompactNumberRu, formatPercentRu } from '../lib/metrics'

const allPosts = getAllPosts()
const channels = getAllChannels().filter((channel) => channel.postCount > 0)
const categories = getAllCategories().filter((category) => category.count > 0)
const postsWithViews = allPosts.filter((post) => typeof post.viewCount === 'number')
const totalKnownViews = postsWithViews.reduce((sum, post) => sum + (post.viewCount || 0), 0)
const averageEngagement =
  postsWithViews.length > 0
    ? postsWithViews.reduce((sum, post) => sum + (post.engagementRate || 0), 0) / postsWithViews.length
    : undefined
const averageViews = postsWithViews.length > 0 ? totalKnownViews / postsWithViews.length : undefined
const channel = getChannelData()
channel.title = `${getDigestTitle()} - Статистика`
channel.description = 'Статистика покрытия по включённым юридическим каналам.'
channel.descriptionHTML = null
channel.avatar = undefined
channel.seo = { title: 'Статистика' }

const SITE_URL = import.meta.env.BASE_URL ?? '/'
const maxChannelPosts = Math.max(...channels.map((item) => item.postCount), 1)
const maxCategoryCount = Math.max(...categories.map((item) => item.count), 1)
const channelSignals = channels.map((item) => {
  const channelPosts = allPosts.filter((post) => post.channel === item.name)
  const channelPostsWithViews = channelPosts.filter((post) => typeof post.viewCount === 'number')
  const avgViews =
    channelPostsWithViews.length > 0
      ? channelPostsWithViews.reduce((sum, post) => sum + (post.viewCount || 0), 0) / channelPostsWithViews.length
      : undefined
  const avgEngagement =
    channelPostsWithViews.length > 0
      ? channelPostsWithViews.reduce((sum, post) => sum + (post.engagementRate || 0), 0) / channelPostsWithViews.length
      : undefined
  return { ...item, avgViews, avgEngagement }
})
const channelsByViews = channelSignals
  .filter((item) => item.avgViews)
  .sort((a, b) => (b.avgViews || 0) - (a.avgViews || 0))
const channelsByEngagement = channelSignals
  .filter((item) => item.avgEngagement)
  .sort((a, b) => (b.avgEngagement || 0) - (a.avgEngagement || 0))
const maxAverageViews = Math.max(...channelsByViews.map((item) => item.avgViews || 0), 1)
const maxAverageEngagement = Math.max(...channelsByEngagement.map((item) => item.avgEngagement || 0), 0.01)
---

<Layout channel={channel}>
  <div class="page-stack">
    <section class="page-hero">
      <div class="page-hero__header">
        <div class="page-hero__copy">
          <p class="page-hero__eyebrow">Охват и объём</p>
          <h1 class="page-hero__title">Статистика покрытия</h1>
          <p class="page-hero__description">Какие каналы реально двигают ленту: по объёму, охвату и вовлечённости.</p>
        </div>
        <div class="page-hero__nav">
          <a href={SITE_URL} class="nav-pill">Лента</a>
          <a href={`${SITE_URL}digests/`} class="nav-pill">Дайджесты</a>
          <a href={`${SITE_URL}compare/`} class="nav-pill">Сравнить</a>
        </div>
      </div>
    </section>

    <div class="metric-grid">
      <article class="metric-card"><strong>{allPosts.length}</strong><span>Всего постов</span></article>
      <article class="metric-card"><strong>{channels.length}</strong><span>Активных каналов</span></article>
      <article class="metric-card"><strong>{categories.length}</strong><span>Категорий</span></article>
      <article class="metric-card"><strong>{postsWithViews.length}</strong><span>Постов с охватом</span></article>
      <article class="metric-card">
        <strong>{formatCompactNumberRu(averageViews)}</strong><span>Средний охват</span>
      </article>
      <article class="metric-card">
        <strong>{formatPercentRu(averageEngagement, 1)}</strong><span>Средняя вовлечённость</span>
      </article>
    </div>

    <section class="surface-card section-stack">
      <h2 style="margin:0;font-size:1.02rem;">Посты по каналам</h2>
      {
        channels.map((item) => (
          <div class="stats-bar-row">
            <span class="stats-channel">
              {item.avatar && (
                <img src={item.avatar} alt={item.title} class="stats-avatar" loading="lazy" width="28" height="28" />
              )}
              <span>@{item.name}</span>
            </span>
            <div class="stats-bar-track">
              <div class="stats-bar-fill" style={`width:${Math.round((item.postCount / maxChannelPosts) * 100)}%;`} />
            </div>
            <strong>{item.postCount}</strong>
          </div>
        ))
      }
    </section>

    <section class="surface-card section-stack">
      <h2 style="margin:0;font-size:1.02rem;">Посты по темам</h2>
      {
        categories.map((item) => (
          <div class="stats-bar-row">
            <span>{item.label}</span>
            <div class="stats-bar-track">
              <div class="stats-bar-fill" style={`width:${Math.round((item.count / maxCategoryCount) * 100)}%;`} />
            </div>
            <strong>{item.count}</strong>
          </div>
        ))
      }
    </section>

    {
      channelsByViews.length > 0 && (
        <section class="surface-card section-stack">
          <h2 style="margin:0;font-size:1.02rem;">Средний охват по каналам</h2>
          {channelsByViews.map((item) => (
            <div class="stats-bar-row">
              <span class="stats-channel">
                {item.avatar && (
                  <img src={item.avatar} alt={item.title} class="stats-avatar" loading="lazy" width="28" height="28" />
                )}
                <span>@{item.name}</span>
              </span>
              <div class="stats-bar-track">
                <div
                  class="stats-bar-fill"
                  style={`width:${Math.round(((item.avgViews || 0) / maxAverageViews) * 100)}%;`}
                />
              </div>
              <strong>{formatCompactNumberRu(item.avgViews)}</strong>
            </div>
          ))}
        </section>
      )
    }

    {
      channelsByEngagement.length > 0 && (
        <section class="surface-card section-stack">
          <h2 style="margin:0;font-size:1.02rem;">Средняя вовлечённость по каналам</h2>
          {channelsByEngagement.map((item) => (
            <div class="stats-bar-row">
              <span class="stats-channel">
                {item.avatar && (
                  <img src={item.avatar} alt={item.title} class="stats-avatar" loading="lazy" width="28" height="28" />
                )}
                <span>@{item.name}</span>
              </span>
              <div class="stats-bar-track">
                <div
                  class="stats-bar-fill"
                  style={`width:${Math.round(((item.avgEngagement || 0) / maxAverageEngagement) * 100)}%;`}
                />
              </div>
              <strong>{formatPercentRu(item.avgEngagement, 1)}</strong>
            </div>
          ))}
        </section>
      )
    }

    <p class="text-dim" style="margin:0;font-size:0.84rem;line-height:1.55;">
      Всего зафиксировано {formatCompactNumberRu(totalKnownViews)} просмотров в постах, где Telegram Web Preview показал счётчик.
    </p>
  </div>
</Layout>

<style>
  .stats-bar-row {
    display: grid;
    gap: 0.7rem;
    grid-template-columns: minmax(10rem, 14rem) minmax(0, 1fr) minmax(3rem, auto);
    align-items: center;
    font-size: 0.9rem;
  }
  .stats-bar-row + .stats-bar-row {
    padding-top: 0.2rem;
  }
  .stats-bar-row span {
    color: var(--color-muted);
  }
  .stats-bar-row strong {
    color: var(--color-heading);
    font-size: 0.84rem;
    text-align: right;
  }
  .stats-bar-track {
    height: 12px;
    background: var(--color-line-light);
    overflow: hidden;
  }
  .stats-bar-fill {
    height: 100%;
    min-width: 4px;
    background: var(--color-heading);
  }
  .stats-channel {
    display: flex;
    align-items: center;
    gap: 0.55rem;
  }
  .stats-avatar {
    width: 28px;
    height: 28px;
    border-radius: 999px;
    object-fit: cover;
    border: 1px solid var(--color-line-light);
  }
  @media (max-width: 768px) {
    .stats-bar-row {
      grid-template-columns: 1fr;
      gap: 0.45rem;
    }
    .stats-bar-row strong {
      text-align: left;
    }
  }
</style>
