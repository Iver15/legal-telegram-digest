---
import Layout from '../../layouts/base.astro'
import { Icon } from 'astro-icon/components'
import { getChannelData, getDigestPayload, getDigestTitle } from '../../lib/data'

const channel = getChannelData()
channel.title = `${getDigestTitle()} - Дайджесты`
channel.description = 'Собранные дайджесты по юридическому приоритету за сегодня, вчера и неделю.'
channel.descriptionHTML = null
channel.avatar = undefined
channel.seo = { title: 'Дайджесты' }

const digests = [getDigestPayload('today'), getDigestPayload('yesterday'), getDigestPayload('week')].filter(Boolean)

const SITE_URL = import.meta.env.BASE_URL ?? '/'
---

<Layout channel={channel}>
  <div class="page-stack">
    <section class="page-hero hero-card--index" style="position:relative;overflow:hidden;">
      <div class="hero-card__accent-glow" aria-hidden="true"></div>
      <div class="page-hero__header">
        <div class="page-hero__copy">
          <p class="page-hero__eyebrow"><span aria-hidden="true">&#128240;</span> Собранные периоды</p>
          <h1 class="page-hero__title">Готовые дайджесты</h1>
          <p class="page-hero__description">
            Собранные дайджесты по периодам — юридический приоритет, свежесть и сигналы аудитории.
          </p>
        </div>
        <div class="page-hero__nav">
          <a href={SITE_URL} class="nav-pill">Лента</a>
          <a href={`${SITE_URL}hot/`} class="nav-pill">Главное</a>
          <a href={`${SITE_URL}compare/`} class="nav-pill">Сравнить</a>
        </div>
      </div>
      <div class="metric-grid">
        {
          digests.map((digest) => (
            <article class="metric-card metric-card--featured">
              <div class="metric-card__icon-wrap" aria-hidden="true">
                <Icon name="ri:file-list-3-line" class="metric-card__icon" />
              </div>
              <div class="metric-card__content">
                <strong>{digest.totalPosts}</strong>
                <span>{digest.label}</span>
              </div>
            </article>
          ))
        }
      </div>
    </section>

    <div class="digest-grid">
      {
        digests.map((digest) => (
          <article class="digest-card surface-card section-stack">
            <div class="digest-card__head">
              <div>
                <h2>{digest.label}</h2>
                <p>
                  {digest.totalPosts} постов · обновлено {new Date(digest.generatedAt).toLocaleString('ru-RU')}
                </p>
              </div>
              <a href={`${SITE_URL}digests/${digest.id}.json`} class="digest-json-link">
                <Icon name="ri:code-s-slash-line" class="digest-json-link__icon" /> JSON
              </a>
            </div>
            <div class="digest-pill-row">
              {digest.topTopics.slice(0, 5).map((topic) => (
                <span class="badge">
                  {topic.label} · {topic.count}
                </span>
              ))}
            </div>
            <div class="digest-list">
              {digest.topPosts.slice(0, 5).map((post) => (
                <a href={`${SITE_URL}posts/${post.id}`} class="digest-list__item">
                  <strong>{post.title || post.digestSummary}</strong>
                  <span>
                    @{post.channel} · приоритет {post.priorityScore?.toFixed(1) || '0.0'}
                  </span>
                </a>
              ))}
            </div>
          </article>
        ))
      }
    </div>
  </div>
</Layout>

<style>
  .digest-grid {
    display: grid;
    gap: var(--section-gap);
    grid-template-columns: repeat(auto-fit, minmax(19rem, 1fr));
    align-items: stretch;
  }
  .digest-card {
    min-height: 100%;
  }
  .digest-card__head {
    display: flex;
    justify-content: space-between;
    gap: 0.9rem;
    align-items: flex-start;
  }
  .digest-card__head h2 {
    margin: 0;
    color: var(--color-heading);
    font-size: 1.04rem;
    line-height: 1.2;
  }
  .digest-card__head p {
    margin: 0.2rem 0 0;
    color: var(--color-muted);
    font-size: 0.84rem;
    line-height: 1.45;
  }
  .digest-json-link {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    padding: 0.32rem 0.62rem;
    border: 1px solid var(--color-line);
    border-radius: 999px;
    background: var(--color-chip);
    color: var(--color-muted);
    font-size: 0.78rem;
    font-weight: 700;
    text-decoration: none;
    white-space: nowrap;
    transition: all 160ms ease;
  }
  .digest-json-link:hover {
    background: color-mix(in srgb, var(--color-accent) 12%, var(--color-surface));
    color: var(--color-accent);
    text-decoration: none;
  }
  .digest-json-link__icon {
    width: 0.85rem;
    height: 0.85rem;
  }
  .digest-pill-row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.45rem;
  }
  .digest-list {
    display: grid;
    gap: 0.55rem;
  }
  .digest-list__item {
    display: grid;
    gap: 0.24rem;
    padding: 0.92rem 0.96rem;
    border-radius: 16px;
    border: 1px solid var(--color-line);
    text-decoration: none;
    background: color-mix(in srgb, var(--color-surface) 92%, transparent);
    transition:
      transform 160ms ease,
      border-color 160ms ease,
      background 160ms ease;
  }
  .digest-list__item:hover {
    transform: translateY(-1px);
    border-color: color-mix(in srgb, var(--color-accent) 24%, var(--color-line));
    text-decoration: none;
  }
  .digest-list__item strong {
    color: var(--color-heading);
    font-size: 0.92rem;
    line-height: 1.35;
  }
  .digest-list__item span {
    color: var(--color-muted);
    font-size: 0.8rem;
    line-height: 1.45;
  }
  @media (max-width: 640px) {
    .digest-card__head {
      flex-direction: column;
    }
  }
</style>
