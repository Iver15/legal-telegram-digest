---
import Layout from '../../layouts/base.astro'
import { getChannelData, getDigestPayload, getDigestTitle } from '../../lib/data'

const channel = getChannelData()
channel.title = `${getDigestTitle()} - Digests`
channel.description = 'Generated legal-priority digests for today, yesterday, and the last week.'
channel.descriptionHTML = null
channel.avatar = undefined
channel.seo = { title: 'Digests' }

const digests = [getDigestPayload('today'), getDigestPayload('yesterday'), getDigestPayload('week')].filter(Boolean)

const SITE_URL = import.meta.env.BASE_URL ?? '/'
---

<Layout channel={channel}>
  <div style="margin-bottom:16px;display:flex;align-items:center;gap:8px;flex-wrap:wrap;">
    <h1 style="font-size:20px;font-weight:600;margin:0;color:var(--color-heading);">Готовые дайджесты</h1>
    <div style="display:flex;gap:4px;margin-left:auto;">
      <a href={SITE_URL} class="nav-pill">Лента</a>
      <a href={`${SITE_URL}hot/`} class="nav-pill">Главное</a>
      <a href={`${SITE_URL}compare/`} class="nav-pill">Сравнить</a>
    </div>
  </div>
  <p class="text-dim" style="font-size:14px;margin:0 0 12px;">
    После синхронизации здесь появляются собранные дайджесты по периодам и их JSON-версии.
  </p>

  <div class="digest-grid">
    {
      digests.map((digest) => (
        <article class="digest-card">
          <div class="digest-card__head">
            <div>
              <h2>{digest.label}</h2>
              <p>
                {digest.totalPosts} постов · обновлено {new Date(digest.generatedAt).toLocaleString('ru-RU')}
              </p>
            </div>
            <a href={`${SITE_URL}digests/${digest.id}.json`}>JSON</a>
          </div>
          <div class="digest-pill-row">
            {digest.topTopics.slice(0, 5).map((topic) => (
              <span class="badge">
                {topic.label} · {topic.count}
              </span>
            ))}
          </div>
          <div class="digest-list">
            {digest.topPosts.slice(0, 5).map((post) => (
              <a href={`${SITE_URL}posts/${post.id}`} class="digest-list__item">
                <strong>{post.title || post.digestSummary}</strong>
                <span>
                  @{post.channel} · приоритет {post.priorityScore?.toFixed(1) || '0.0'}
                </span>
              </a>
            ))}
          </div>
        </article>
      ))
    }
  </div>
</Layout>

<style>
  .digest-grid {
    display: grid;
    gap: 1rem;
  }
  .digest-card {
    border: 1px solid var(--color-line);
    border-radius: 16px;
    padding: 1rem;
    background: var(--color-surface);
  }
  .digest-card__head {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: 0.8rem;
  }
  .digest-card__head h2 {
    margin: 0;
    color: var(--color-heading);
    font-size: 1rem;
  }
  .digest-card__head p {
    margin: 0.2rem 0 0;
    color: var(--color-muted);
    font-size: 0.84rem;
  }
  .digest-pill-row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    margin-bottom: 0.8rem;
  }
  .digest-list {
    display: grid;
    gap: 0.55rem;
  }
  .digest-list__item {
    display: grid;
    gap: 0.18rem;
    padding: 0.75rem;
    border-radius: 12px;
    border: 1px solid var(--color-line);
    text-decoration: none;
  }
  .digest-list__item strong {
    color: var(--color-heading);
    font-size: 0.92rem;
  }
  .digest-list__item span {
    color: var(--color-muted);
    font-size: 0.8rem;
  }
</style>
