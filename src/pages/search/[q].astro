---
import type { GetStaticPaths } from 'astro'
import List from '../../components/list.astro'
import { getAllChannels, getAllTags, getChannelData } from '../../lib/data'

export const getStaticPaths: GetStaticPaths = () => {
  const tags = getAllTags()
  const channels = getAllChannels()
    .map((channel) => channel.name)
    .filter(Boolean)

  const entries = new Set<string>()

  for (const tag of tags) {
    entries.add(`#${tag}`)
    entries.add(tag)
    entries.add(`%23${tag}`)
  }

  for (const channel of channels) {
    entries.add(channel)
  }

  return Array.from(entries).map((q) => ({ params: { q } }))
}

const q = decodeURIComponent(Astro.params.q || '')
const channel = getChannelData({ q })

channel.seo = {
  title: `${q}`,
  noindex: true,
}
---

<List channel={channel} before={false} after={false} pageHeading={`Поиск: ${q}`} />
