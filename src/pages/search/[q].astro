---
import type { GetStaticPaths } from 'astro'
import List from '../../components/list.astro'
import { getAllTags, getChannelData } from '../../lib/data'

export const getStaticPaths: GetStaticPaths = () => {
  const tags = getAllTags()
  return tags.flatMap((tag) => [{ params: { q: `#${tag}` } }, { params: { q: tag } }, { params: { q: `%23${tag}` } }])
}

const q = decodeURIComponent(Astro.params.q || '')
const channel = getChannelData({ q })

channel.seo = {
  title: `${q}`,
  noindex: true,
}
---

<List channel={channel} before={false} after={false} pageHeading={`Search: ${q}`} />
