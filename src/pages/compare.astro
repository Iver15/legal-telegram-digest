---
import Layout from '../layouts/base.astro'
import { getAllChannels, getAllPosts, getChannelData, getDigestTitle } from '../lib/data'
import { formatCompactNumberRu, formatPercentRu } from '../lib/metrics'

const channels = getAllChannels().filter((channel) => channel.postCount > 0)
const posts = getAllPosts()
const channel = getChannelData()
channel.title = `${getDigestTitle()} - Сравнение`
channel.description = 'Сравнение каналов по объёму, юридическому приоритету, охвату и вовлечённости.'
channel.descriptionHTML = null
channel.avatar = undefined
channel.seo = { title: 'Сравнение' }

const SITE_URL = import.meta.env.BASE_URL ?? '/'
const rows = channels
  .map((item) => {
    const channelPosts = posts.filter((post) => post.channel === item.name)
    const totalPriority = channelPosts.reduce((sum, post) => sum + (post.priorityScore || 0), 0)
    const averagePriority = channelPosts.length > 0 ? totalPriority / channelPosts.length : 0
    const totalReactions = channelPosts.reduce((sum, post) => sum + (post.reactionCount || 0), 0)
    const postsWithViews = channelPosts.filter((post) => typeof post.viewCount === 'number')
    const averageViews =
      postsWithViews.length > 0
        ? postsWithViews.reduce((sum, post) => sum + (post.viewCount || 0), 0) / postsWithViews.length
        : undefined
    const averageEngagement =
      postsWithViews.length > 0
        ? postsWithViews.reduce((sum, post) => sum + (post.engagementRate || 0), 0) / postsWithViews.length
        : undefined
    const viewCoverage = channelPosts.length > 0 ? postsWithViews.length / channelPosts.length : 0
    const lastPostAt = channelPosts[0]?.datetime

    return {
      ...item,
      totalPriority,
      averagePriority,
      totalReactions,
      averageViews,
      averageEngagement,
      viewCoverage,
      lastPostAt,
    }
  })
  .sort(
    (a, b) =>
      b.averagePriority - a.averagePriority ||
      (b.averageEngagement || 0) - (a.averageEngagement || 0) ||
      (b.averageViews || 0) - (a.averageViews || 0) ||
      b.postCount - a.postCount,
  )
const withViews = rows.filter((row) => row.averageViews)
const avgPriority = rows.length ? rows.reduce((sum, row) => sum + row.averagePriority, 0) / rows.length : 0
const avgCoverage = rows.length ? rows.reduce((sum, row) => sum + row.viewCoverage, 0) / rows.length : 0
---

<Layout channel={channel}>
  <div class="page-stack">
    <section class="compare-hero page-hero">
      <div class="page-hero__header">
        <div class="page-hero__copy">
          <p class="page-hero__eyebrow">Сводка источников</p>
          <h1 class="page-hero__title">Сравнение каналов</h1>
          <p class="page-hero__description compare-hero__text">
            Сравнение активных источников: объём, средний юридический приоритет, охват на пост и вовлечённость
            аудитории.
          </p>
        </div>
        <div class="page-hero__nav">
          <a href={SITE_URL} class="nav-pill">Лента</a>
          <a href={`${SITE_URL}digests/`} class="nav-pill">Дайджесты</a>
          <a href={`${SITE_URL}stats/`} class="nav-pill">Статистика</a>
        </div>
      </div>
      <div class="compare-hero__stats metric-grid">
        <article class="metric-card"><strong>{rows.length}</strong><span>каналов</span></article>
        <article class="metric-card">
          <strong>{avgPriority.toFixed(2)}</strong><span>ср. приоритет</span>
        </article>
        <article class="metric-card">
          <strong>{formatPercentRu(avgCoverage, 0)}</strong><span>покрытие просмотров</span>
        </article>
        <article class="metric-card">
          <strong>{withViews.length}</strong><span>каналов с охватом</span>
        </article>
      </div>
    </section>

    <div class="compare-table-wrap surface-card table-card">
      <table class="compare-table data-table">
        <thead>
          <tr>
            <th>Канал</th>
            <th>Категория</th>
            <th>Посты</th>
            <th>Средний приоритет</th>
            <th>Средний охват</th>
            <th>Вовлечённость</th>
            <th>Покрытие просмотров</th>
            <th>Реакции</th>
            <th>Последний пост</th>
          </tr>
        </thead>
        <tbody>
          {
            rows.map((row) => (
              <tr>
                <td data-label="Канал">
                  <a href={`${SITE_URL}search/${row.name}`} class="compare-channel">
                    {row.avatar && (
                      <img
                        src={row.avatar}
                        alt={row.title}
                        class="compare-channel__avatar"
                        loading="lazy"
                        width="32"
                        height="32"
                      />
                    )}
                    <span>
                      <>
                        <strong>@{row.name}</strong>
                        <em>{row.title}</em>
                      </>
                    </span>
                  </a>
                </td>
                <td data-label="Категория">{row.category || 'общее'}</td>
                <td data-label="Посты">{row.postCount}</td>
                <td data-label="Средний приоритет">{row.averagePriority.toFixed(2)}</td>
                <td data-label="Средний охват">{formatCompactNumberRu(row.averageViews)}</td>
                <td data-label="Вовлечённость">{formatPercentRu(row.averageEngagement, 1)}</td>
                <td data-label="Покрытие просмотров">{formatPercentRu(row.viewCoverage, 0)}</td>
                <td data-label="Реакции">{formatCompactNumberRu(row.totalReactions)}</td>
                <td data-label="Последний пост">
                  {row.lastPostAt ? new Date(row.lastPostAt).toLocaleDateString('ru-RU') : '—'}
                </td>
              </tr>
            ))
          }
        </tbody>
      </table>
    </div>
    <p class="text-dim compare-note">
      Просмотры берутся только из Telegram Web Preview. Если Telegram их не показал для части постов, метрики охвата и
      вовлечённости считаются по доступным записям.
    </p>
  </div>
</Layout>

<style>
  .compare-table-wrap {
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
  }
  .compare-table {
    min-width: 56rem;
  }
  .compare-table td {
    font-size: 0.92rem;
    line-height: 1.5;
  }
  .compare-note {
    margin: 0;
    font-size: 0.84rem;
    line-height: 1.55;
  }
  @media (max-width: 720px) {
    .compare-table,
    .compare-table thead,
    .compare-table tbody,
    .compare-table tr,
    .compare-table td {
      display: block;
      min-width: 0;
    }
    .compare-table {
      min-width: 0;
    }
    .compare-table thead {
      display: none;
    }
    .compare-table tr {
      margin: 0.75rem;
      padding: 0.35rem 0;
      border: 1px solid var(--color-line);
      border-radius: 18px;
      background: color-mix(in srgb, var(--color-surface) 92%, transparent);
    }
    .compare-table td {
      border-bottom: none;
      padding: 0.52rem 0.95rem;
    }
    .compare-table td::before {
      content: attr(data-label);
      display: block;
      margin-bottom: 0.22rem;
      color: var(--color-muted);
      font-size: 0.72rem;
      text-transform: uppercase;
      letter-spacing: 0.04em;
    }
  }
  .compare-hero__text {
    margin: 0;
  }
  .compare-hero__stats {
    margin-top: 0.1rem;
  }
  .compare-channel {
    display: flex;
    align-items: center;
    gap: 0.7rem;
    text-decoration: none;
  }
  .compare-channel__avatar {
    width: 32px;
    height: 32px;
    border-radius: 999px;
    object-fit: cover;
    border: 1px solid var(--color-line);
  }
  .compare-channel span {
    display: grid;
    gap: 0.12rem;
  }
  .compare-channel strong {
    color: var(--color-heading);
    font-size: 0.88rem;
  }
  .compare-channel em {
    color: var(--color-muted);
    font-style: normal;
    font-size: 0.76rem;
  }
</style>
