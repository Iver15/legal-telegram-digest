---
import type { GetStaticPaths } from 'astro'
import voidFile from '../../assets/void.png'
import List from '../../components/list.astro'
import { getAllPostIds, getChannelData, getPost } from '../../lib/data'

export const getStaticPaths: GetStaticPaths = () => {
  return getAllPostIds().map((id) => ({ params: { id } }))
}

const { id } = Astro.params
const channelInfo = getChannelData()
const post = getPost(id!)

if (!post) {
  return Astro.redirect('/')
}

const channel = {
  ...(channelInfo || {}),
  posts: [post],
  seo: post,
}

const SITE_URL = import.meta.env.BASE_URL ?? '/'
const breadcrumbClass = 'mb-5 py-[10px] font-semibold'
const breadcrumbListClass = 'm-0 flex list-none items-center p-0'
const breadcrumbLinkClass = 'inline-flex items-center no-underline'
const breadcrumbAvatarClass = 'block h-5 w-5 rounded-full border-2 border-white object-cover shadow-soft'
const breadcrumbTitleClass = 'ml-[10px] flex-1 text-[14px] text-heading'
---

<List channel={channel} before={false} after={false} isItem={true} pageHeading={post.title || channel.title}>
  <section slot="header" class="mb-5 rounded-[22px] border border-line bg-card p-4 sm:p-5">
    <nav aria-label="Хлебные крошки" class="mb-4">
      <a
        href={SITE_URL}
        class="inline-flex items-center gap-2 text-sm font-semibold text-dim no-underline hover:no-underline"
      >
        <span class="text-lg">&larr;</span> Назад к ленте
      </a>
    </nav>
    <div class="flex flex-wrap items-center gap-2">
      {post.channel && <span class="badge">@{post.channel}</span>}
      {post.category && <span class="badge">{post.category}</span>}
      {post.priorityScore && <span class="badge">приоритет {post.priorityScore.toFixed(1)}</span>}
    </div>
    <h1 class="mt-3 font-[var(--font-display)] text-[clamp(1.7rem,3vw,2.4rem)] leading-[1.05] text-heading">
      {post.title || channel.title}
    </h1>
    {post.datetime && <p class="mt-3 text-sm text-dim">{new Date(post.datetime).toLocaleString('ru-RU')}</p>}
    <div class="mt-3 flex flex-wrap items-center gap-2">
      {typeof post.viewCount === 'number' && <span class="badge">👁 {post.viewCount.toLocaleString('ru-RU')}</span>}
      {
        typeof post.reactionCount === 'number' && post.reactionCount > 0 && (
          <span class="badge">❤ {post.reactionCount.toLocaleString('ru-RU')}</span>
        )
      }
      {typeof post.engagementRate === 'number' && <span class="badge">ER {post.engagementRate.toFixed(2)}%</span>}
    </div>
  </section>
</List>
