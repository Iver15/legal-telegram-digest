---
import type { GetStaticPaths } from 'astro'
import { Icon } from 'astro-icon/components'
import List from '../../components/list.astro'
import { getAllPostIds, getChannelData, getPost } from '../../lib/data'
import { formatCompactNumberRu, formatPercentRu } from '../../lib/metrics'
import dayjs from '../../lib/dayjs'
import { getPostDisplayTitle } from '../../lib/ui'

export const getStaticPaths: GetStaticPaths = () => {
  return getAllPostIds().map((id) => ({ params: { id } }))
}

const { id } = Astro.params
const channelInfo = getChannelData()
const post = getPost(id!)

if (!post) {
  return Astro.redirect('/')
}

const displayTitle = getPostDisplayTitle(post, channelInfo?.title || 'Пост')

const channel = {
  ...(channelInfo || {}),
  posts: [post],
  seo: {
    ...post,
    title: displayTitle,
  },
}

const SITE_URL = import.meta.env.BASE_URL ?? '/'
const locale = import.meta.env.LOCALE || 'ru'
const timezone = import.meta.env.TIMEZONE || 'Europe/Moscow'
locale && dayjs.locale(locale)

const datetime = dayjs(post.datetime).tz(timezone)
const formattedDate = datetime.format('D MMMM YYYY, HH:mm')

const allIds = getAllPostIds()
const currentIndex = allIds.indexOf(id!)
const prevId = currentIndex > 0 ? allIds[currentIndex - 1] : null
const nextId = currentIndex < allIds.length - 1 ? allIds[currentIndex + 1] : null
const prevPost = prevId ? getPost(prevId) : null
const nextPost = nextId ? getPost(nextId) : null

const wordCount = (post.text || '').split(/\s+/).filter(Boolean).length
const readingMinutes = Math.max(1, Math.round(wordCount / 200))
const legalTopics = post.legalTopics || []
const priorityScore = post.priorityScore || 0
const viewCount = post.viewCount
const reactionCount = post.reactionCount
const engagementRate = post.engagementRate
const hasSignals =
  (reactionCount && reactionCount > 0) || typeof viewCount === 'number' || typeof engagementRate === 'number'
const channelAvatar = post.channelAvatar
const tgChannel = post.channel || ''
const postNumericId = post.id.includes('/') ? post.id.split('/').pop() : post.id
const tgLink = `https://t.me/${tgChannel}/${postNumericId}`
---

<List channel={channel} before={false} after={false} isItem={true} pageHeading={displayTitle}>
  <section slot="header" class="post-detail-header">
    <nav class="post-detail-nav">
      <a href={SITE_URL} class="post-detail-back">
        <Icon name="ri:arrow-left-line" style="width:1rem;height:1rem;" />
        Назад к ленте
      </a>
      <div class="post-detail-actions">
        <button class="post-detail-share" title="Скопировать ссылку" onclick="copyPostLink(this)">
          <Icon name="ri:link" style="width:1rem;height:1rem;" />
        </button>
        <a href={tgLink} target="_blank" rel="noopener noreferrer" class="post-detail-tg">
          <Icon name="ri:telegram-line" style="width:0.95rem;height:0.95rem;" />
          Telegram
        </a>
      </div>
    </nav>

    <div class="post-detail-channel">
      {
        channelAvatar && (
          <img
            src={channelAvatar}
            alt={post.channelTitle || tgChannel}
            class="post-detail-avatar"
            loading="lazy"
            width="44"
            height="44"
          />
        )
      }
      <div>
        <strong style="color:var(--color-heading);font-size:0.96rem;">{post.channelTitle || 'Канал'}</strong>
        {
          tgChannel && (
            <span class="text-dim" style="font-size:0.82rem;margin-left:0.4rem;">
              @{tgChannel}
            </span>
          )
        }
      </div>
      {
        post.category && (
          <span class="badge" data-cat={post.category}>
            {post.category}
          </span>
        )
      }
    </div>

    <h1 class="post-detail-title">{displayTitle}</h1>

    <div class="post-detail-meta">
      {
        post.datetime && (
          <span class="text-dim" style="font-size:0.85rem;">
            {formattedDate}
          </span>
        )
      }
      <span class="text-dim" style="font-size:0.85rem;">· {readingMinutes} мин чтения</span>
      {
        legalTopics.length > 0 &&
          legalTopics.slice(0, 4).map((topic) => (
            <a href={`${SITE_URL}search/%23${topic}/`} class="badge">
              #{topic}
            </a>
          ))
      }
      {
        priorityScore > 0 && (
          <span
            class:list={[
              'priority-badge',
              priorityScore >= 7 && 'priority-badge--high',
              priorityScore >= 4 && priorityScore < 7 && 'priority-badge--medium',
            ]}
          >
            {priorityScore.toFixed(1)}
          </span>
        )
      }
    </div>

    {
      hasSignals && (
        <div class="post-detail-signals">
          {typeof viewCount === 'number' && (
            <span class="signal-chip signal-chip--views">
              <Icon name="ri:eye-line" class="signal-chip__icon" />
              {formatCompactNumberRu(viewCount)}
            </span>
          )}
          {reactionCount && reactionCount > 0 && (
            <span class="signal-chip signal-chip--reactions">
              <Icon name="ri:heart-line" class="signal-chip__icon" />
              {formatCompactNumberRu(reactionCount)}
            </span>
          )}
          {typeof engagementRate === 'number' && (
            <span class="signal-chip signal-chip--er">
              <Icon name="ri:bar-chart-line" class="signal-chip__icon" />
              {formatPercentRu(engagementRate, 1)}
            </span>
          )}
        </div>
      )
    }
  </section>

  <div slot="footer">
    <a href={tgLink} target="_blank" rel="noopener noreferrer" class="post-detail-cta">
      <Icon name="ri:telegram-line" style="width:1.25rem;height:1.25rem;" />
      Читать оригинал в Telegram
      <Icon name="ri:external-link-line" style="width:0.85rem;height:0.85rem;opacity:0.6;" />
    </a>

    <nav class="post-detail-pager">
      {
        prevPost ? (
          <a href={`${SITE_URL}posts/${prevId}/`} class="post-detail-pager-link">
            <Icon
              name="ri:arrow-left-s-line"
              style="width:1.25rem;height:1.25rem;color:var(--color-muted);flex-shrink:0;"
            />
            <div>
              <span class="post-detail-pager-label">Новее</span>
              <span class="post-detail-pager-title">
                {getPostDisplayTitle(prevPost, prevPost.channelTitle || prevId || 'Пост')}
              </span>
            </div>
          </a>
        ) : (
          <span />
        )
      }
      {
        nextPost ? (
          <a
            href={`${SITE_URL}posts/${nextId}/`}
            class="post-detail-pager-link"
            style="text-align:right;justify-content:flex-end;"
          >
            <div>
              <span class="post-detail-pager-label">Старше</span>
              <span class="post-detail-pager-title">
                {getPostDisplayTitle(nextPost, nextPost.channelTitle || nextId || 'Пост')}
              </span>
            </div>
            <Icon
              name="ri:arrow-right-s-line"
              style="width:1.25rem;height:1.25rem;color:var(--color-muted);flex-shrink:0;"
            />
          </a>
        ) : (
          <span />
        )
      }
    </nav>
  </div>
</List>

<div
  class="reading-progress"
  id="reading-progress"
  data-prev={prevId ? `${SITE_URL}posts/${prevId}/` : ''}
  data-next={nextId ? `${SITE_URL}posts/${nextId}/` : ''}
>
</div>
<div class="copy-toast" id="copy-toast">Ссылка скопирована</div>

<script is:inline>
  /* eslint-disable no-var, vars-on-top, unused-imports/no-unused-vars, antfu/if-newline, prefer-template, prefer-arrow-callback */
  ;(function () {
    var bar = document.getElementById('reading-progress')
    if (!bar) return
    function update() {
      var h = document.documentElement.scrollHeight - window.innerHeight
      var pct = h > 0 ? (window.scrollY / h) * 100 : 0
      bar.style.width = pct + '%'
    }
    window.addEventListener('scroll', update, { passive: true })
    update()
  })()
  function copyPostLink() {
    navigator.clipboard.writeText(window.location.href).then(function () {
      var toast = document.getElementById('copy-toast')
      if (toast) {
        toast.classList.add('copy-toast--visible')
        setTimeout(function () {
          toast.classList.remove('copy-toast--visible')
        }, 2000)
      }
    })
  }
  document.addEventListener('keydown', function (e) {
    if (e.target.tagName === 'INPUT' || e.target.tagName === 'TEXTAREA') return
    var el = document.getElementById('reading-progress')
    if (!el) return
    if (e.key === 'k' && el.dataset.prev) window.location.href = el.dataset.prev
    if (e.key === 'j' && el.dataset.next) window.location.href = el.dataset.next
  })
</script>

<style is:global>
  .reading-progress {
    position: fixed;
    top: 0;
    left: 0;
    width: 0;
    height: 3px;
    background: var(--color-accent);
    z-index: 1300;
    transition: width 80ms linear;
    pointer-events: none;
  }
  .copy-toast {
    position: fixed;
    bottom: 6rem;
    left: 50%;
    transform: translateX(-50%) translateY(1rem);
    padding: 0.6rem 1.1rem;
    background: var(--color-heading);
    color: var(--color-paper);
    font-size: 0.85rem;
    font-weight: 600;
    opacity: 0;
    pointer-events: none;
    transition:
      opacity 200ms ease,
      transform 200ms ease;
    z-index: 1300;
  }
  .copy-toast--visible {
    opacity: 1;
    transform: translateX(-50%) translateY(0);
  }

  .post-detail-header {
    display: grid;
    gap: 0.85rem;
    margin-bottom: 1.25rem;
    padding: clamp(1rem, 0.7vw + 0.84rem, 1.4rem);
    border: 1px solid var(--color-line);
    background: var(--color-surface);
  }
  .post-detail-nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
    flex-wrap: wrap;
  }
  .post-detail-back {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.88rem;
    font-weight: 600;
    color: var(--color-muted);
    text-decoration: none;
  }
  .post-detail-back:hover {
    color: var(--color-accent);
    text-decoration: none;
  }
  .post-detail-actions {
    display: flex;
    gap: 0.5rem;
    align-items: center;
  }
  .post-detail-share {
    appearance: none;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.1rem;
    height: 2.1rem;
    border: 1px solid var(--color-line);
    background: transparent;
    color: var(--color-muted);
    cursor: pointer;
    padding: 0;
  }
  .post-detail-share:hover {
    background: var(--color-chip);
    color: var(--color-accent);
  }
  .post-detail-tg {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    padding: 0.38rem 0.72rem;
    border: 1px solid var(--color-line);
    background: transparent;
    color: var(--color-accent);
    font-size: 0.82rem;
    font-weight: 700;
    text-decoration: none;
  }
  .post-detail-tg:hover {
    background: var(--color-chip);
    text-decoration: none;
  }
  .post-detail-channel {
    display: flex;
    align-items: center;
    gap: 0.65rem;
    flex-wrap: wrap;
  }
  .post-detail-avatar {
    width: 2.75rem;
    height: 2.75rem;
    border-radius: 999px;
    object-fit: cover;
    border: 1px solid var(--color-line);
    flex-shrink: 0;
  }
  .post-detail-title {
    margin: 0;
    font-family: var(--font-display);
    font-size: clamp(1.55rem, 2.5vw + 0.5rem, 2.3rem);
    line-height: 1.08;
    color: var(--color-heading);
  }
  .post-detail-meta {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.45rem;
  }
  .post-detail-signals {
    display: flex;
    flex-wrap: wrap;
    gap: 0.55rem;
  }

  .post-detail-cta {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.6rem;
    margin-top: 1.5rem;
    padding: 0.85rem 1.2rem;
    border: 1px solid var(--color-line);
    background: var(--color-surface);
    color: var(--color-accent);
    font-size: 0.95rem;
    font-weight: 700;
    text-decoration: none;
  }
  .post-detail-cta:hover {
    background: var(--color-accent);
    border-color: var(--color-accent);
    color: #fff;
    text-decoration: none;
  }

  .post-detail-pager {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.75rem;
    margin-top: 1rem;
    margin-bottom: 0.5rem;
  }
  .post-detail-pager-link {
    display: flex;
    align-items: center;
    gap: 0.65rem;
    padding: 0.85rem 1rem;
    border: 1px solid var(--color-line);
    background: var(--color-surface);
    color: inherit;
    text-decoration: none;
    min-width: 0;
  }
  .post-detail-pager-link:hover {
    border-color: var(--color-accent);
    text-decoration: none;
  }
  .post-detail-pager-label {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--color-accent);
    display: block;
  }
  .post-detail-pager-title {
    font-size: 0.88rem;
    font-weight: 600;
    color: var(--color-heading);
    line-height: 1.35;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  @media (max-width: 768px) {
    .post-detail-header {
      padding: 0.85rem;
      gap: 0.65rem;
    }
    .post-detail-title {
      font-size: clamp(1.15rem, 4.5vw, 1.6rem);
      line-height: 1.15;
    }
    .post-detail-avatar {
      width: 2.25rem;
      height: 2.25rem;
    }
    .post-detail-cta {
      padding: 0.72rem 1rem;
      font-size: 0.88rem;
    }
    .post-detail-pager {
      grid-template-columns: 1fr;
      gap: 0.5rem;
    }
    .post-detail-pager-link {
      padding: 0.7rem 0.85rem;
    }
    .post-detail-pager-title {
      -webkit-line-clamp: 1;
      font-size: 0.82rem;
    }
    .reading-progress {
      height: 2px;
    }
    .copy-toast {
      bottom: 7rem;
      font-size: 0.8rem;
      padding: 0.5rem 0.9rem;
    }
  }
</style>
