---
import Layout from '../layouts/base.astro'
import Header from '../components/header.astro'
import TagCloudSection from '../components/TagCloudSection.astro'
import { getAllPosts, getAllTags, getChannelData } from '../lib/data'

const SITE_URL = import.meta.env.BASE_URL ?? '/'

const channel = getChannelData()

channel.seo = {
  title: 'Теги',
}

const tagCounts = new Map<string, number>()
for (const post of getAllPosts()) {
  for (const tag of post.tags || []) {
    tagCounts.set(tag, (tagCounts.get(tag) || 0) + 1)
  }
}

function pluralRu(n: number, forms: [string, string, string]): string {
  const n10 = n % 10
  const n100 = n % 100
  if (n10 === 1 && n100 !== 11) return forms[0]
  if (n10 >= 2 && n10 <= 4 && (n100 < 12 || n100 > 14)) return forms[1]
  return forms[2]
}

const items = getAllTags()
  .map((tag) => {
    const count = tagCounts.get(tag) || 0
    const noun = pluralRu(count, ['пост', 'поста', 'постов'])
    return {
      href: `${SITE_URL}search/%23${tag}/`,
      label: tag,
      count,
      title: `${count} ${noun} с тегом #${tag}`,
    }
  })
  .sort((a, b) => b.count - a.count || a.label.localeCompare(b.label, 'ru'))

const description =
  items.length > 0
    ? `Теги отсортированы по частоте — сначала те, что встречаются чаще. Всего тегов: ${items.length}.`
    : undefined
---

<Layout channel={channel}>
  <Header channel={channel} />
  <TagCloudSection title="Теги" description={description} items={items} />
</Layout>
