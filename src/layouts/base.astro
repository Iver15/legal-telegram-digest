---
import '../styles/app.css'
import { SEO } from 'astro-seo'
import { Icon } from 'astro-icon/components'
import type { NavItem } from '../types'
import { getSiteMeta } from '../lib/data'

const SITE_URL = import.meta.env.BASE_URL ?? '/'
const RSS_URL = `${SITE_URL}rss.xml`
const { channel } = Astro.props
const siteMeta = getSiteMeta()

const locale = import.meta.env.LOCALE || 'ru'
const seo = channel?.seo

function normalizePathname(pathname: string): string {
  return pathname.replace(/\/$/, '') || '/'
}

const absoluteSiteUrl = SITE_URL.startsWith('http') ? SITE_URL : new URL(SITE_URL, Astro.url.origin).toString()
const canonicalUrl = new URL(Astro.url.pathname, absoluteSiteUrl)
const siteRootPathname = normalizePathname(new URL(absoluteSiteUrl).pathname)
const canonical =
  normalizePathname(canonicalUrl.pathname) === siteRootPathname
    ? canonicalUrl.toString()
    : canonicalUrl.toString().replace(/\/$/, '')

const { pathname } = new URL(canonical)
const currentPathname = normalizePathname(pathname)
const twitter = import.meta.env.TWITTER
const pageTitle = seo?.title?.trim()
const siteTitle = channel?.title ?? ''
const seoDescription = seo?.text ?? channel?.description
const shareImage = channel?.avatar
  ? `https://wsrv.nl/?w=1200&h=630&fit=cover&url=ssl:${channel.avatar.replace(/^https?:\/\//, '')}`
  : new URL('favicon.ico', absoluteSiteUrl).toString()
const favicon = channel?.avatar
  ? `https://wsrv.nl/?w=64&h=64&fit=cover&mask=circle&url=ssl:${channel.avatar.replace(/^https?:\/\//, '')}`
  : new URL('favicon.svg', absoluteSiteUrl).toString()
const hasCustomTitle = Boolean(pageTitle && pageTitle !== siteTitle)
const isArticle = /\/posts\/[^/]+$/.test(pathname)
const tagsPathname = normalizePathname(new URL('tags', absoluteSiteUrl).pathname)
const linksPathname = normalizePathname(new URL('links', absoluteSiteUrl).pathname)
const hotPathname = normalizePathname(new URL('hot', absoluteSiteUrl).pathname)
const statsPathname = normalizePathname(new URL('stats', absoluteSiteUrl).pathname)
const comparePathname = normalizePathname(new URL('compare', absoluteSiteUrl).pathname)
const digestsPathname = normalizePathname(new URL('digests', absoluteSiteUrl).pathname)

const seoParams = {
  title: pageTitle,
  description: seoDescription,
  canonical,
  noindex: seo?.noindex ?? import.meta.env.NOINDEX,
  nofollow: seo?.nofollow ?? import.meta.env.NOFOLLOW,
  openGraph: {
    basic: {
      type: isArticle ? 'article' : 'website',
      title: pageTitle ?? siteTitle,
      url: canonical,
      image: shareImage,
    },
    optional: {
      description: seoDescription,
      locale,
    },
  },
  extend: {
    link: [
      { rel: 'icon', href: favicon },
      { rel: 'apple-touch-icon', href: `${SITE_URL}favicon.ico` },
      { rel: 'manifest', href: `${SITE_URL}manifest.json` },
    ],
  },
}

const TAGS = import.meta.env.TAGS
const LINKS = import.meta.env.LINKS
const HEADER_INJECT = import.meta.env.HEADER_INJECT
const FOOTER_INJECT = import.meta.env.FOOTER_INJECT
const navs: NavItem[] = (import.meta.env.NAVS || '')
  .split(';')
  .filter(Boolean)
  .map((link: string) => {
    const [title = '', href = ''] = link.split(',')
    return { title, href }
  })

const PUSH_SERVER_URL = import.meta.env.PUSH_SERVER_URL || ''
const VAPID_PUBLIC_KEY = import.meta.env.VAPID_PUBLIC_KEY || ''

const today = new Date().toLocaleDateString('ru-RU', { day: '2-digit', month: '2-digit', year: 'numeric' })
---

<!doctype html>
<html lang={locale ?? 'ru'} data-push-url={PUSH_SERVER_URL} data-vapid-key={VAPID_PUBLIC_KEY}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="theme-color" content="#FFFFFF" />
    <link rel="alternate" type="application/rss+xml" title={channel?.title} href={RSS_URL} />
    <SEO
      titleTemplate={hasCustomTitle ? `%s | ${siteTitle}` : undefined}
      titleDefault={siteTitle || seoParams.description}
      twitter={{
        card: 'summary_large_image',
        creator: twitter ? `@${twitter}` : undefined,
      }}
      {...seoParams}
    />
    <Fragment set:html={HEADER_INJECT} />
    <script is:inline src={`${import.meta.env.BASE_URL ?? '/'}theme.js`}></script>
  </head>

  <body>
    <a href="#main-content" class="skip-link">Перейти к содержимому</a>

    <div class="page">
      <!-- HEADER -->
      <header class="page-header">
        <div class="page-header__top">
          <span class="page-header__label">Юридический Telegram-дайджест</span>
          <span class="page-header__date">{today}</span>
        </div>
        <h1 class="page-header__title">{siteMeta.shortTitle || siteMeta.title}</h1>
        <slot name="metrics" />
      </header>

      <!-- COMMAND BAR (optional, provided by pages) -->
      <slot name="command-bar" />

      <!-- MAIN CONTENT -->
      <main class="page-main" id="main-content">
        <slot />
      </main>

      <!-- SIDEBAR -->
      <aside class="page-sidebar">
        <div class="sidebar__section">
          <div class="sidebar__label">Система</div>
          <div class="sidebar__title">{siteMeta.shortTitle || 'Юрдайджест'}</div>
          <p class="sidebar__description">{siteMeta.description}</p>
        </div>

        <div class="sidebar__section">
          <div class="sidebar__label">Навигация</div>
          <ul class="sidebar-nav">
            <li class:list={[currentPathname === siteRootPathname && 'active']}>
              <a href={SITE_URL}>Лента</a>
            </li>
            <li class:list={[currentPathname === digestsPathname && 'active']}>
              <a href={`${SITE_URL}digests/`}>Дайджесты</a>
            </li>
            <li class:list={[currentPathname === hotPathname && 'active']}>
              <a href={`${SITE_URL}hot/`}>Главное</a>
            </li>
            <li class:list={[currentPathname === comparePathname && 'active']}>
              <a href={`${SITE_URL}compare/`}>Сравнить</a>
            </li>
            <li class:list={[currentPathname === statsPathname && 'active']}>
              <a href={`${SITE_URL}stats/`}>Статистика</a>
            </li>
            {
              TAGS ? (
                <li class:list={[currentPathname === tagsPathname && 'active']}>
                  <a href={`${SITE_URL}tags`}>Теги</a>
                </li>
              ) : null
            }
            {
              LINKS ? (
                <li class:list={[currentPathname === linksPathname && 'active']}>
                  <a href={`${SITE_URL}links`}>Ссылки</a>
                </li>
              ) : null
            }
            {
              navs.map((nav) => (
                <li>
                  <a href={nav.href} target="_blank" rel="noopener noreferrer">
                    {nav.title}
                  </a>
                </li>
              ))
            }
          </ul>
        </div>

        <div class="sidebar__section">
          <div class="sidebar__label">Поиск</div>
          <form action={`${SITE_URL}search/result`} method="get" role="search">
            <label class="sr-only" for="search-query">Поиск</label>
            <input
              id="search-query"
              class="sidebar-search"
              type="search"
              name="q"
              placeholder="Поиск по каналу, теме..."
              autocomplete="off"
              inputmode="search"
              spellcheck={false}
            />
          </form>
        </div>

        <button id="theme-toggle" class="theme-btn" onclick="toggleTheme()">Dark / Light</button>

        <div class="sidebar-footer">
          Основано на
          <a href="https://github.com/miantiao-me/BroadcastChannel" target="_blank" rel="noopener noreferrer">
            BroadcastChannel
          </a>.
        </div>
      </aside>

      <!-- FOOTER -->
      <footer class="page-footer">
        Transfer Channel RSS &middot; {siteMeta.shortTitle || siteMeta.title} &middot; {new Date().getFullYear()}
      </footer>
    </div>

    <!-- MOBILE DOCK -->
    <nav class="mobile-dock" aria-label="Быстрая навигация">
      <div class="mobile-dock__inner">
        <a
          href={SITE_URL}
          class:list={['mobile-dock__link', currentPathname === siteRootPathname && 'mobile-dock__link--active']}
        >
          <Icon name="ri:newspaper-line" class="mobile-dock__icon" />
          <span>Лента</span>
        </a>
        <a
          href={`${SITE_URL}digests/`}
          class:list={['mobile-dock__link', currentPathname === digestsPathname && 'mobile-dock__link--active']}
        >
          <Icon name="ri:calendar-line" class="mobile-dock__icon" />
          <span>Дайджесты</span>
        </a>
        <a
          href={`${SITE_URL}hot/`}
          class:list={['mobile-dock__link', currentPathname === hotPathname && 'mobile-dock__link--active']}
        >
          <Icon name="ri:fire-line" class="mobile-dock__icon" />
          <span>Главное</span>
        </a>
        <a
          href={`${SITE_URL}compare/`}
          class:list={['mobile-dock__link', currentPathname === comparePathname && 'mobile-dock__link--active']}
        >
          <Icon name="ri:scales-3-line" class="mobile-dock__icon" />
          <span>Сравнить</span>
        </a>
        <a
          href={`${SITE_URL}stats/`}
          class:list={['mobile-dock__link', currentPathname === statsPathname && 'mobile-dock__link--active']}
        >
          <Icon name="ri:bar-chart-box-line" class="mobile-dock__icon" />
          <span>Стат.</span>
        </a>
      </div>
    </nav>

    <div id="back-to-top-wrapper">
      <a href="#main-content" id="back-to-top" aria-label="Наверх">
        <svg class="back-to-top__ring" viewBox="0 0 36 36" width="40" height="40">
          <circle cx="18" cy="18" r="16" fill="none" stroke="var(--color-line-light)" stroke-width="2"></circle>
          <circle
            id="btt-progress"
            cx="18"
            cy="18"
            r="16"
            fill="none"
            stroke="var(--color-accent)"
            stroke-width="2.5"
            stroke-linecap="round"
            stroke-dasharray="100.53"
            stroke-dashoffset="100.53"
            transform="rotate(-90 18 18)"></circle>
        </svg>
        <Icon name="ri:arrow-up-line" class="back-to-top__icon" />
      </a>
    </div>

    <Fragment set:html={FOOTER_INJECT} />

    <script is:inline>
      /* eslint-disable no-var, vars-on-top, antfu/if-newline, prefer-arrow-callback */
      // Image gallery: horizontal carousel for posts with multiple images
      ;(function () {
        var containers = document.querySelectorAll('.image-list-container')
        containers.forEach(function (container) {
          var buttons = container.querySelectorAll('.image-preview-button')
          if (buttons.length <= 1 || !container.parentNode) return

          container.setAttribute('data-carousel', 'true')

          var shell = document.createElement('div')
          shell.className = 'image-gallery-shell'
          container.parentNode.insertBefore(shell, container)
          shell.appendChild(container)

          var prev = document.createElement('button')
          prev.className = 'image-gallery-nav image-gallery-nav--prev'
          prev.type = 'button'
          prev.setAttribute('aria-label', 'Предыдущее изображение')
          prev.innerHTML = '&#8249;'

          var next = document.createElement('button')
          next.className = 'image-gallery-nav image-gallery-nav--next'
          next.type = 'button'
          next.setAttribute('aria-label', 'Следующее изображение')
          next.innerHTML = '&#8250;'

          var status = document.createElement('div')
          status.className = 'image-gallery-status'

          shell.appendChild(prev)
          shell.appendChild(next)
          shell.appendChild(status)

          function getCurrentIndex() {
            var index = Math.round(container.scrollLeft / Math.max(container.clientWidth, 1))
            return Math.max(0, Math.min(index, buttons.length - 1))
          }

          function updateState() {
            var index = getCurrentIndex()
            status.textContent = `${index + 1} / ${buttons.length}`
            prev.disabled = index === 0
            next.disabled = index >= buttons.length - 1
          }

          function scrollToIndex(index) {
            var target = buttons[index]
            if (!target) return
            target.scrollIntoView({ behavior: 'smooth', block: 'nearest', inline: 'start' })
          }

          prev.addEventListener('click', function () {
            scrollToIndex(getCurrentIndex() - 1)
          })

          next.addEventListener('click', function () {
            scrollToIndex(getCurrentIndex() + 1)
          })

          container.addEventListener(
            'scroll',
            function () {
              window.requestAnimationFrame(updateState)
            },
            { passive: true },
          )

          window.addEventListener('resize', updateState, { passive: true })
          updateState()
        })
      })()
      ;(function () {
        var ring = document.getElementById('btt-progress')
        if (!ring) return
        var circumference = 2 * Math.PI * 16
        ring.style.strokeDasharray = circumference
        ring.style.strokeDashoffset = circumference
        window.addEventListener(
          'scroll',
          function () {
            var h = document.documentElement.scrollHeight - window.innerHeight
            var pct = h > 0 ? window.scrollY / h : 0
            ring.style.strokeDashoffset = circumference * (1 - pct)
          },
          { passive: true },
        )
      })()
    </script>
    <script is:inline src={`${import.meta.env.BASE_URL}pwa.js`}></script>
    <div id="install-banner" class="install-banner">
      <div class="install-banner__copy">
        <div class="install-banner__title">{siteMeta.shortTitle || siteMeta.title}</div>
        <div class="install-banner__text">Установите сайт как приложение для быстрого чтения и офлайн-доступа</div>
      </div>
      <button onclick="installApp()" class="install-banner__primary">Установить</button>
      <button onclick="dismissInstall()" class="install-banner__dismiss" aria-label="Close">&times;</button>
    </div>
  </body>
</html>
