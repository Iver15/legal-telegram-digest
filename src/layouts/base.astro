---
import '../styles/app.css'
import { SEO } from 'astro-seo'
import { Icon } from 'astro-icon/components'
import backToTopIcon from '../assets/back-to-top.svg'
import type { NavItem } from '../types'
import { getSiteMeta } from '../lib/data'

const SITE_URL = import.meta.env.BASE_URL ?? '/'
const RSS_URL = `${SITE_URL}rss.xml`
const { channel } = Astro.props
const siteMeta = getSiteMeta()

const locale = import.meta.env.LOCALE || 'ru'
const seo = channel?.seo

function normalizePathname(pathname: string): string {
  return pathname.replace(/\/$/, '') || '/'
}

const absoluteSiteUrl = SITE_URL.startsWith('http') ? SITE_URL : new URL(SITE_URL, Astro.url.origin).toString()
const canonicalUrl = new URL(Astro.url.pathname, absoluteSiteUrl)
const siteRootPathname = normalizePathname(new URL(absoluteSiteUrl).pathname)
const canonical =
  normalizePathname(canonicalUrl.pathname) === siteRootPathname
    ? canonicalUrl.toString()
    : canonicalUrl.toString().replace(/\/$/, '')

const { pathname } = new URL(canonical)
const currentPathname = normalizePathname(pathname)
const twitter = import.meta.env.TWITTER
const pageTitle = seo?.title?.trim()
const siteTitle = channel?.title ?? ''
const seoDescription = seo?.text ?? channel?.description
const shareImage = channel?.avatar
  ? `https://wsrv.nl/?w=1200&h=630&fit=cover&url=ssl:${channel.avatar.replace(/^https?:\/\//, '')}`
  : new URL('favicon.ico', absoluteSiteUrl).toString()
const favicon = channel?.avatar
  ? `https://wsrv.nl/?w=64&h=64&fit=cover&mask=circle&url=ssl:${channel.avatar.replace(/^https?:\/\//, '')}`
  : new URL('favicon.svg', absoluteSiteUrl).toString()
const hasCustomTitle = Boolean(pageTitle && pageTitle !== siteTitle)
const isArticle = /\/posts\/[^/]+$/.test(pathname)
const tagsPathname = normalizePathname(new URL('tags', absoluteSiteUrl).pathname)
const linksPathname = normalizePathname(new URL('links', absoluteSiteUrl).pathname)
const hotPathname = normalizePathname(new URL('hot', absoluteSiteUrl).pathname)
const statsPathname = normalizePathname(new URL('stats', absoluteSiteUrl).pathname)
const comparePathname = normalizePathname(new URL('compare', absoluteSiteUrl).pathname)
const digestsPathname = normalizePathname(new URL('digests', absoluteSiteUrl).pathname)

const seoParams = {
  title: pageTitle,
  description: seoDescription,
  canonical,
  noindex: seo?.noindex ?? import.meta.env.NOINDEX,
  nofollow: seo?.nofollow ?? import.meta.env.NOFOLLOW,
  openGraph: {
    basic: {
      type: isArticle ? 'article' : 'website',
      title: pageTitle ?? siteTitle,
      url: canonical,
      image: shareImage,
    },
    optional: {
      description: seoDescription,
      locale,
    },
  },
  extend: {
    link: [
      { rel: 'icon', href: favicon },
      { rel: 'apple-touch-icon', href: `${SITE_URL}favicon.ico` },
      { rel: 'manifest', href: `${SITE_URL}manifest.json` },
    ],
  },
}

const TAGS = import.meta.env.TAGS
const LINKS = import.meta.env.LINKS
const HEADER_INJECT = import.meta.env.HEADER_INJECT
const FOOTER_INJECT = import.meta.env.FOOTER_INJECT
const navs: NavItem[] = (import.meta.env.NAVS || '')
  .split(';')
  .filter(Boolean)
  .map((link: string) => {
    const [title = '', href = ''] = link.split(',')
    return { title, href }
  })

const PUSH_SERVER_URL = import.meta.env.PUSH_SERVER_URL || ''
const VAPID_PUBLIC_KEY = import.meta.env.VAPID_PUBLIC_KEY || ''

const layoutShellClass = 'layout-shell px-3 py-3 sm:px-4 sm:py-4 xl:px-5 xl:py-[1.15rem]'
const layoutGridClass =
  'layout-grid reader-shell-card mx-auto grid w-full max-w-[var(--page-max-width)] grid-cols-1 gap-4 p-3 sm:p-4 lg:grid-cols-[minmax(0,1fr)_300px] lg:gap-5 lg:p-5 xl:grid-cols-[minmax(0,1fr)_320px] xl:gap-5 xl:p-6'
const mainPanelClass = 'layout-main w-full min-w-0 pb-4 lg:pb-6'
const asidePanelClass = 'w-full min-w-0 lg:sticky lg:top-6 lg:self-start'
const asideInnerClass = 'relative grid gap-4 overflow-y-visible lg:max-h-[calc(100dvh-3rem)] lg:overflow-y-auto lg:pr-1'
const navListClass = 'm-0 flex list-none flex-wrap gap-2 pl-0 lg:grid lg:gap-2'
const navItemClass = 'flex items-center text-[14px] leading-none lg:text-[15px] lg:leading-normal'
const navLinkClass =
  'sidebar-nav-link flex-1 inline-flex items-center rounded-[14px] border border-line px-3 py-[0.7rem] text-heading no-underline transition-[background-color,box-shadow,border-color] duration-150 ease-in-out hover:no-underline hover:shadow-soft'
const navLinkCurrentClass = 'sidebar-nav-active shadow-soft'
const skipLinkClass =
  'pointer-events-none absolute left-5 top-0 z-[1100] -translate-y-full rounded-panel bg-heading px-3 py-2 text-sm text-white no-underline transition-transform duration-150 focus-visible:pointer-events-auto focus-visible:translate-y-5 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-heading'
const searchFormClass = 'rounded-[18px] border border-line bg-code/80 p-2 text-muted shadow-soft backdrop-blur'
const searchInputClass =
  'box-border w-full rounded-[14px] border border-transparent bg-transparent px-3 py-2 text-[15px] leading-[1.6] text-muted outline-none placeholder:text-muted focus-visible:border-heading focus-visible:outline focus-visible:outline-1 focus-visible:outline-offset-2 focus-visible:outline-heading lg:text-[13px]'
const footerClass = 'hidden px-2 pt-1 text-[13px] leading-[1.6] text-footer lg:block'
const backToTopClass =
  'pointer-events-auto z-[1000] flex h-10 w-10 items-center justify-center rounded-full border border-line bg-code/95 text-[24px] opacity-90 shadow-soft backdrop-blur transition-transform duration-300 hover:-translate-y-[3px] active:translate-y-px'
const backToTopIconClass = 'h-auto w-auto [filter:var(--icon-secondary-filter)]'
const mobileDockClass = 'mobile-dock lg:hidden'
const mobileDockLinkClass = 'mobile-dock__link'
const mobileDockLinkCurrentClass = 'mobile-dock__link--active'
---

<!doctype html>
<html lang={locale ?? 'ru'} data-push-url={PUSH_SERVER_URL} data-vapid-key={VAPID_PUBLIC_KEY}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="theme-color" content="#f4f1ec" />
    <link rel="alternate" type="application/rss+xml" title={channel?.title} href={RSS_URL} />
    <SEO
      titleTemplate={hasCustomTitle ? `%s | ${siteTitle}` : undefined}
      titleDefault={siteTitle || seoParams.description}
      twitter={{
        card: 'summary_large_image',
        creator: twitter ? `@${twitter}` : undefined,
      }}
      {...seoParams}
    />
    <Fragment set:html={HEADER_INJECT} />
    <script is:inline src={`${import.meta.env.BASE_URL ?? '/'}theme.js`}></script>
  </head>

  <body>
    <a href="#main-content" class={skipLinkClass}>Перейти к содержимому</a>
    <main id="main-content" class={layoutShellClass}>
      <div class={layoutGridClass}>
        <div class={mainPanelClass}>
          <slot />
        </div>
        <aside class={asidePanelClass}>
          <slot name="aside">
            <div class={asideInnerClass}>
              <section class="brand-card">
                <div class="brand-card__top-row">
                  <p class="brand-card__eyebrow">Юридический дайджест</p>
                  <button
                    id="theme-toggle"
                    onclick="toggleTheme()"
                    class="theme-toggle-btn"
                    aria-label="Переключить тему"
                  >
                    &#127769;
                  </button>
                </div>
                <h1 class="brand-card__title">{siteMeta.shortTitle || siteMeta.title}</h1>
                <p class="brand-card__description">{siteMeta.description}</p>
                <div class="brand-card__meta">
                  <span class="badge">публичные каналы</span>
                  <span class="badge">юридический дайджест</span>
                  <span class="badge">мобильный режим</span>
                </div>
              </section>
              <nav aria-label="Основная навигация">
                <ul class={navListClass}>
                  <li class={navItemClass}>
                    <a
                      href={SITE_URL}
                      title={channel?.title}
                      class:list={[navLinkClass, currentPathname === siteRootPathname && navLinkCurrentClass]}
                    >
                      Лента
                    </a>
                  </li>
                  {
                    TAGS ? (
                      <li class={navItemClass}>
                        <a
                          href={`${SITE_URL}tags`}
                          title="Теги"
                          class:list={[navLinkClass, currentPathname === tagsPathname && navLinkCurrentClass]}
                        >
                          Теги
                        </a>
                      </li>
                    ) : null
                  }
                  {
                    LINKS ? (
                      <li class={navItemClass}>
                        <a
                          href={`${SITE_URL}links`}
                          title="Ссылки"
                          class:list={[navLinkClass, currentPathname === linksPathname && navLinkCurrentClass]}
                        >
                          Ссылки
                        </a>
                      </li>
                    ) : null
                  }
                  <li class={navItemClass}>
                    <a
                      href={`${SITE_URL}digests/`}
                      title="Дайджесты"
                      class:list={[navLinkClass, currentPathname === digestsPathname && navLinkCurrentClass]}
                    >
                      Дайджесты
                    </a>
                  </li>
                  <li class={navItemClass}>
                    <a
                      href={`${SITE_URL}hot/`}
                      title="Главное"
                      class:list={[navLinkClass, currentPathname === hotPathname && navLinkCurrentClass]}
                    >
                      Главное
                    </a>
                  </li>
                  <li class={navItemClass}>
                    <a
                      href={`${SITE_URL}compare/`}
                      title="Сравнить"
                      class:list={[navLinkClass, currentPathname === comparePathname && navLinkCurrentClass]}
                    >
                      Сравнить
                    </a>
                  </li>
                  <li class={navItemClass}>
                    <a
                      href={`${SITE_URL}stats/`}
                      title="Статистика"
                      class:list={[navLinkClass, currentPathname === statsPathname && navLinkCurrentClass]}
                    >
                      Статистика
                    </a>
                  </li>
                  {
                    navs.map((nav) => (
                      <li class={navItemClass}>
                        <a
                          href={nav.href}
                          title={nav.title}
                          target="_blank"
                          rel="noopener noreferrer"
                          class={navLinkClass}
                        >
                          {nav.title}
                        </a>
                      </li>
                    ))
                  }
                </ul>
              </nav>

              <form class={searchFormClass} action={`${SITE_URL}search/result`} method="get" role="search">
                <label class="sr-only" for="search-query">Поиск</label>
                <input
                  id="search-query"
                  class={searchInputClass}
                  type="search"
                  name="q"
                  placeholder="Поиск по каналу, теме или ключевому слову"
                  autocomplete="off"
                  inputmode="search"
                  spellcheck={false}
                />
              </form>

              <footer class={footerClass}>
                Основано на
                <a
                  href="https://github.com/miantiao-me/BroadcastChannel"
                  title="BroadcastChannel"
                  target="_blank"
                  rel="noopener noreferrer"
                >
                  BroadcastChannel
                </a>
                .
              </footer>
            </div>
          </slot>
        </aside>
      </div>
      <div id="back-to-top-wrapper">
        <a href="#main-content" id="back-to-top" class={backToTopClass} aria-label="Наверх">
          <svg class="back-to-top__ring" viewBox="0 0 36 36" width="40" height="40">
            <circle cx="18" cy="18" r="16" fill="none" stroke="var(--color-line)" stroke-width="2"></circle>
            <circle
              id="btt-progress"
              cx="18"
              cy="18"
              r="16"
              fill="none"
              stroke="var(--color-accent)"
              stroke-width="2.5"
              stroke-linecap="round"
              stroke-dasharray="100.53"
              stroke-dashoffset="100.53"
              transform="rotate(-90 18 18)"></circle>
          </svg>
          <Icon name="ri:arrow-up-line" class="back-to-top__icon" />
        </a>
      </div>
    </main>
    <nav class={mobileDockClass} aria-label="Быстрая навигация">
      <div class="mobile-dock__inner">
        <a
          href={SITE_URL}
          class:list={[mobileDockLinkClass, currentPathname === siteRootPathname && mobileDockLinkCurrentClass]}
        >
          <Icon name="ri:newspaper-line" class="mobile-dock__icon" />
          <span>Лента</span>
        </a>
        <a
          href={`${SITE_URL}digests/`}
          class:list={[mobileDockLinkClass, currentPathname === digestsPathname && mobileDockLinkCurrentClass]}
        >
          <Icon name="ri:calendar-line" class="mobile-dock__icon" />
          <span>Дайджесты</span>
        </a>
        <a
          href={`${SITE_URL}hot/`}
          class:list={[mobileDockLinkClass, currentPathname === hotPathname && mobileDockLinkCurrentClass]}
        >
          <Icon name="ri:fire-line" class="mobile-dock__icon" />
          <span>Главное</span>
        </a>
        <a
          href={`${SITE_URL}compare/`}
          class:list={[mobileDockLinkClass, currentPathname === comparePathname && mobileDockLinkCurrentClass]}
        >
          <Icon name="ri:scales-3-line" class="mobile-dock__icon" />
          <span>Сравнить</span>
        </a>
        <a
          href={`${SITE_URL}stats/`}
          class:list={[mobileDockLinkClass, currentPathname === statsPathname && mobileDockLinkCurrentClass]}
        >
          <Icon name="ri:bar-chart-box-line" class="mobile-dock__icon" />
          <span>Стат.</span>
        </a>
      </div>
    </nav>

    <Fragment set:html={FOOTER_INJECT} />

    <script is:inline>
      /* eslint-disable no-var, vars-on-top, antfu/if-newline, prefer-arrow-callback */
      // Image gallery: collage with "show more" for >4 images
      ;(function () {
        var containers = document.querySelectorAll('.image-list-container')
        containers.forEach(function (container) {
          var buttons = container.querySelectorAll('.image-preview-button')
          if (buttons.length <= 4) return
          container.classList.add('image-list-has-more')
          var fourth = buttons[3]
          if (fourth) fourth.setAttribute('data-remaining', `+${buttons.length - 3}`)
          var toggle = document.createElement('button')
          toggle.className = 'image-gallery-toggle'
          toggle.textContent = `Показать все ${buttons.length} фото`
          toggle.type = 'button'
          container.parentNode.insertBefore(toggle, container.nextSibling)
          toggle.addEventListener('click', function () {
            var expanded = container.classList.toggle('image-gallery-expanded')
            toggle.textContent = expanded ? 'Свернуть' : `Показать все ${buttons.length} фото`
          })
        })
      })()
      ;(function () {
        var ring = document.getElementById('btt-progress')
        if (!ring) return
        var circumference = 2 * Math.PI * 16
        ring.style.strokeDasharray = circumference
        ring.style.strokeDashoffset = circumference
        window.addEventListener(
          'scroll',
          function () {
            var h = document.documentElement.scrollHeight - window.innerHeight
            var pct = h > 0 ? window.scrollY / h : 0
            ring.style.strokeDashoffset = circumference * (1 - pct)
          },
          { passive: true },
        )
      })()
    </script>
    <script is:inline src={`${import.meta.env.BASE_URL}pwa.js`}></script>
    <div id="install-banner" class="install-banner">
      <div class="install-banner__copy">
        <div class="install-banner__title">{siteMeta.shortTitle || siteMeta.title}</div>
        <div class="install-banner__text">Установите сайт как приложение для быстрого чтения и офлайн-доступа</div>
      </div>
      <button onclick="installApp()" class="install-banner__primary">Установить</button>
      <button onclick="dismissInstall()" class="install-banner__dismiss" aria-label="Close">&times;</button>
    </div>
  </body>
</html>
