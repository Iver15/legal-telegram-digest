# Optional single-channel fallback.
# Preferred: edit data/channels.json and keep enabled channels there.
CHANNEL=pravoinf

# Site
LOCALE=ru
TIMEZONE=Europe/Moscow
SITE_URL=
BASE_PATH=/legal-telegram-digest/
TELEGRAM_HOST=t.me

# Fetch
MAX_PAGES=3
DOWNLOAD_MEDIA=true

# Reader UI
REACTIONS=true
COMMENTS=
LINKS=
NAVS=
NOINDEX=false
NOFOLLOW=false
HIDE_DESCRIPTION=false

# Optional mirror deployment
SOURCECRAFT_TOKEN=
SOURCECRAFT_REPO=
